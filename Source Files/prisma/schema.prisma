generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model UserProfile {
  id                String   @id @default(cuid())
  clerkUserId       String   @unique
  name              String
  goal              String
  skillLevel        String
  dailyGoal         String
  preferredLanguage String
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  problems          Problem[]
  notes             Note[]
  conversations     AIConversation[]
  learningPlans     LearningPlan[]
}

model Problem {
  id          String   @id @default(cuid())
  userId      String
  title       String
  topic       String
  difficulty  String
  status      String
  link        String?
  isTodayGoal Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        UserProfile @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ProblemCatalog {
  id          String   @id @default(cuid())
  title       String
  topic       String
  difficulty  String
  leetcodeUrl String   @unique
  pattern     String?
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Note {
  id        String   @id @default(cuid())
  userId    String
  title     String
  linkedTo  String
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      UserProfile @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AIConversation {
  id        String   @id @default(cuid())
  userId    String
  title     String   @default("New conversation")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      UserProfile @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages  AIMessage[]
}

model AIMessage {
  id             String   @id @default(cuid())
  conversationId String
  role           String
  content        String
  createdAt      DateTime @default(now())

  conversation   AIConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
}

model LearningPlan {
  id          String   @id @default(cuid())
  userId      String
  title       String
  topic       String
  status      String   @default("Active")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        UserProfile @relation(fields: [userId], references: [id], onDelete: Cascade)
  items       LearningPlanItem[]
}

model LearningPlanItem {
  id             String   @id @default(cuid())
  learningPlanId String
  title          String
  topic          String
  difficulty     String
  link           String?
  order          Int
  completed      Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  learningPlan   LearningPlan @relation(fields: [learningPlanId], references: [id], onDelete: Cascade)
}